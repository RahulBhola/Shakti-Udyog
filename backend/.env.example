# ---------------------------------------------------------------------------
# Shakti Udyog backend — environment variable examples
#
# Copy the values you need into your local environment, launch profile, or
# `dotnet user-secrets`. NEVER commit real credentials, connection strings
# with passwords, API keys, or tokens to source control.
# ---------------------------------------------------------------------------

# ASP.NET Core environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development

# SQL Server connection string.
# Windows auth (local dev — adjust the instance name, e.g. localhost\SQLEXPRESS or localhost):
ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=ShaktiUdyogDev;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true
# SQL auth alternative (e.g. SQL Server in Docker) — replace placeholders:
# ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=ShaktiUdyogDev;User Id=<DB_USER>;Password=<DB_PASSWORD>;TrustServerCertificate=True

# Allowed frontend origin for CORS
Frontend__BaseUrl=http://localhost:5173

# --- JWT (Milestone 2 — required) ------------------------------------------
# Signing key: strong random secret, at least 32 bytes. Generate with:
#   openssl rand -base64 48
# or PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
# The API refuses to start without it. Prefer `dotnet user-secrets` locally.
Jwt__SigningKey=<GENERATE_STRONG_RANDOM_SECRET_MIN_32_BYTES>
Jwt__Issuer=ShaktiUdyog.Api
Jwt__Audience=ShaktiUdyog.Clients
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# Development-only demo admin (skipped when unset; never set in production).
# Must satisfy the password policy: 12+ chars, upper, lower, digit, symbol.
# DevAdmin__Password=<LOCAL_DEV_ONLY_PASSWORD>

# Email/SMTP (later milestone)
# Email__SmtpHost=<SMTP_HOST>
# Email__SmtpUser=<SMTP_USER>
# Email__SmtpPassword=<SMTP_PASSWORD>

# Jira integration (later milestone — dedicated service account)
# Jira__BaseUrl=<JIRA_BASE_URL>
# Jira__ServiceAccountEmail=<JIRA_SERVICE_ACCOUNT>
# Jira__ApiToken=<JIRA_API_TOKEN>

# Private file storage (later milestone)
# Storage__ConnectionString=<PRIVATE_STORAGE_CONNECTION>

# Payment gateway (later milestone — server-side keys only)
# Payments__Provider=<PROVIDER>
# Payments__SecretKey=<PAYMENT_SECRET_KEY>
