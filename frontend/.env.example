# ---------------------------------------------------------------------------
# Shakti Udyog frontend — environment variable examples
# Copy to `.env.local` for local development. Vite exposes only variables
# prefixed with VITE_ to the browser — NEVER put secrets, API keys, or
# credentials here; anything in this file ships to the client.
# ---------------------------------------------------------------------------

# Base URL of the backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000
